<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Task manager</title>
</head>
<body>
    <!-- Activity 4: Insert code here to include the header (found in the partials folder) to your page -->
    <%- include('partials/header') %>
    
    <div class="container mt-3">
        <h2>Task Manager</h2>
        <form action="/comfirm" method="post">
            <div class="mb-3 mt-3">
                <label for="title">Title:</label>
                <input type="title" class="form-control" id="title" placeholder="Enter Title" name="title">
            </div>
            <div class="mb-3 mt-3">
                <label for="description">Description:</label>
                <input type="description" class="form-control" id="description" placeholder="Enter Description" name="description">
            </div>
            <div class="mb-3 mt-3">
                <label for="dealine">Dealine:</label>
                <input type="date" class="form-control" id="dealine" placeholder="dd/yy/mm" name="dealine">
            </div>
            <div class="mb-3 mt-3">
                <label for="priority">Priority:</label>
                <textarea class="form-control" id="priority" placeholder="Enter priority" name="priority"></textarea>
            </div>
            
            <!-- Activity 3: Edit contact.ejs to include more form fields – Contact No. and Comments: -->
            
            <button type="confirm" class="btn btn-primary">Submit</button>
        </form>
    </div>
</body>
</html>
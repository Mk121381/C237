<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="/css/style.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Edit Mood - Daily Mood</title>
    <style>
        body {
            background: #d4eaff !important;
            font-family: 'Segoe UI', 'Quicksand', system-ui, sans-serif;
            min-height: 100vh;
            padding-bottom: 2rem;
        }

        .edit-card {
            background: white;
            border-radius: 28px;
            box-shadow: 0 12px 28px rgba(0, 0, 0, 0.08);
            padding: 2rem 2rem 2rem 2rem;
            transition: transform 0.2s;
            margin-top: 1rem;
        }
        .edit-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 18px 32px rgba(0, 0, 0, 0.12);
        }
        h2 {
            color: #2c6e9e;
            font-weight: 700;
            border-left: 6px solid #6ab9ff;
            padding-left: 1rem;
            margin-bottom: 1rem;
        }
        .form-label {
            font-weight: 600;
            color: #2c6e9e;
            margin-bottom: 0.5rem;
        }
        .form-control, .form-select {
            border-radius: 16px;
            border: 1px solid #cde5f5;
            padding: 0.6rem 1rem;
            transition: 0.2s;
        }
        .form-control:focus, .form-select:focus {
            border-color: #6ab9ff;
            box-shadow: 0 0 0 3px rgba(106, 185, 255, 0.2);
            outline: none;
        }
        textarea.form-control {
            border-radius: 20px;
        }
        .btn-primary {
            background: #5fa7cf;
            border: none;
            border-radius: 60px;
            padding: 0.5rem 1.8rem;
            font-weight: 600;
            transition: 0.2s;
        }
        .btn-primary:hover {
            background: #3f8aba;
            transform: scale(1.02);
        }
        .btn-secondary {
            background: #e9ecef;
            border: none;
            border-radius: 60px;
            padding: 0.5rem 1.8rem;
            font-weight: 600;
            color: #5a6c7e;
        }
        .btn-secondary:hover {
            background: #d4d9df;
        }
        hr {
            background: #cde5f5;
            height: 1px;
            margin: 1rem 0;
        }
    </style>
</head>
<body>
    <%- include('partials/navbar.ejs') %>
    <div class="container mt-3">
        <div class="edit-card">
            <h2><i class="bi bi-pencil-square"></i> Edit Mood Record</h2>
            
            <form action="/moods/<%= updateMood.id %>/update" method="POST">
                <div class="mb-3">
                    <label for="date" class="form-label"><i class="bi bi-calendar-heart"></i> Date</label>
                    <input type="date" class="form-control" id="date" name="date" value="<%= updateMood.date %>" required>
                </div>
                
                <div class="mb-3">
                    <label for="mood" class="form-label"><i class="bi bi-emoji-laughing"></i> Mood</label>
                    <select class="form-select" id="mood" name="mood" required>
                        <option value="Happy" <%= updateMood.mood === 'Happy' ? 'selected' : '' %>>😊 Happy</option>
                        <option value="Calm" <%= updateMood.mood === 'Calm' ? 'selected' : '' %>>😌 Calm</option>
                        <option value="Excited" <%= updateMood.mood === 'Excited' ? 'selected' : '' %>>🤩 Excited</option>
                        <option value="Tired" <%= updateMood.mood === 'Tired' ? 'selected' : '' %>>😫 Tired</option>
                        <option value="Sad" <%= updateMood.mood === 'Sad' ? 'selected' : '' %>>😢 Sad</option>
                    </select>
                </div>
                
                <div class="mb-3">
                    <label for="energy" class="form-label"><i class="bi bi-star-fill"></i> Energy Level (1-5)</label>
                    <input type="number" class="form-control" id="energy" name="energy" min="1" max="5" value="<%= updateMood.energy %>" required>
                </div>
                
                <div class="mb-3">
                    <label for="comment" class="form-label"><i class="bi bi-chat-right-quote"></i> Comment</label>
                    <textarea class="form-control" id="comment" name="comment" rows="3"><%= updateMood.comment %></textarea>
                </div>
                
                <div class="mt-4">
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Save Changes</button>
                    <a href="/moodlist" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Cancel</a>
                </div>
            </form>
        </div>
    </div>
    <%- include('partials/footer.ejs') %>
</body>
</html>
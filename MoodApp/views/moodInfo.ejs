<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="/css/style.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Mood Details - Daily Mood</title>
    <style>
        body {
            background: #d4eaff !important;
            font-family: 'Segoe UI', 'Quicksand', system-ui, sans-serif;
            min-height: 100vh;
            padding-bottom: 2rem;
        }
      
        .details-card {
            background: white;
            border-radius: 28px;
            box-shadow: 0 12px 28px rgba(0, 0, 0, 0.08);
            padding: 2rem;
            transition: transform 0.2s;
            margin-top: 1rem;
        }
        .details-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 18px 32px rgba(0, 0, 0, 0.12);
        }
  
        h2 {
            color: #2c6e9e;
            font-weight: 700;
            border-left: 6px solid #6ab9ff;
            padding-left: 1rem;
            margin-bottom: 1.5rem;
        }

        .info-section {
            margin-bottom: 1.2rem;
            padding-bottom: 0.8rem;
            border-bottom: 1px solid #e9f0f5;
        }
        .info-label {
            font-weight: 600;
            color: #2c6e9e;
            display: inline-block;
            width: 120px;
            font-size: 1rem;
        }
        .info-value {
            color: #2c3e4e;
            font-size: 1rem;
        }

        .stars-display {
            font-size: 1.3rem;
            letter-spacing: 3px;
            color: #f7b32b;
            display: inline-block;
        }

        .comment-box {
            background: #f8fcff;
            border-radius: 24px;
            padding: 0.8rem 1.2rem;
            margin-top: 0.3rem;
            border-left: 4px solid #6ab9ff;
            font-style: italic;
            color: #3a6d8c;
        }
        .btn-edit {
            background: #5fa7cf;
            border: none;
            border-radius: 60px;
            padding: 0.5rem 1.8rem;
            font-weight: 600;
            color: white;
            transition: 0.2s;
        }
        .btn-edit:hover {
            background: #3f8aba;
            transform: scale(1.02);
            color: white;
        }
        .btn-back {
            background: #e9ecef;
            border: none;
            border-radius: 60px;
            padding: 0.5rem 1.8rem;
            font-weight: 600;
            color: #5a6c7e;
            transition: 0.2s;
        }
        .btn-back:hover {
            background: #d4d9df;
        }
    </style>
</head>
<body>
    <%- include('partials/navbar.ejs') %>
    <div class="container mt-4">
        <div class="details-card">

            <h2><i class="bi bi-emoji-smile"></i> Mood Details</h2>
            
            <!-- mood -->
            <div class="info-section">
                <span class="info-label"><i class="bi bi-emoji-laughing"></i> Mood:</span>
                <span class="info-value">
                    <% if (mood.mood === 'Happy') { %>😊
                    <% } else if (mood.mood === 'Calm') { %>😌
                    <% } else if (mood.mood === 'Excited') { %>🤩
                    <% } else if (mood.mood === 'Tired') { %>😫
                    <% } else if (mood.mood === 'Sad') { %>😢
                    <% } %>
                    <%= mood.mood %>
                </span>
            </div>
            
            <!-- date -->
            <div class="info-section">
                <span class="info-label"><i class="bi bi-calendar-heart"></i> Date:</span>
                <span class="info-value"><%= mood.date %></span>
            </div>
            
            <!-- the rating -->
            <div class="info-section">
                <span class="info-label"><i class="bi bi-star-fill"></i> Energy:</span>
                <span class="stars-display">
                    <% for (let star = 1; star <= 5; star++) { %>
                        <%= star <= mood.energy ? '★' : '☆' %>
                    <% } %>
                </span>
            </div>
            
            <!-- comment -->
            <div class="info-section">
                <span class="info-label"><i class="bi bi-chat-right-quote"></i> Comment:</span>
                <div class="comment-box">
                    <%= mood.comment || '<span class="text-muted">— No comment —</span>' %>
                </div>
            </div>
            
            <div class="mt-4 d-flex gap-3">
                <a href="/moods/<%= mood.id %>/update" class="btn btn-edit">
                    <i class="bi bi-pencil-square"></i> Edit
                </a>
                <a href="/moodlist" class="btn btn-back">
                    <i class="bi bi-arrow-left"></i> Back to List
                </a>
            </div>
        </div>
    </div>
    <%- include('partials/footer.ejs') %>
</body>
</html>